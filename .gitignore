# ── Rust build artifacts ────────────────────────────────────────────────────
target/
circuit/target/

# Cargo.lock is kept for binaries (service, input-gen, circuit) to ensure
# reproducible builds; omit this line if you want to ignore it.
# Cargo.lock

# ── Circuit ELF ─────────────────────────────────────────────────────────────
# The pre-built ELF is tracked at circuit/elf/circuit.elf so other contributors
# can run the service without needing the +zisk toolchain.
# circuit/elf/circuit.elf  ← intentionally tracked

# ── Generated / runtime data ─────────────────────────────────────────────────
# ZisK binary inputs (regenerated via `make gen-input`)
data/*/aggregated_bn254/zisk_full_verify_input.bin
# Proof output directories produced by cargo-zisk prove
data/*/aggregated_bn254/zisk_proof_*/
data/*/aggregated_bn254/*.bin
data/*/aggregated_bn254/summary.json

# ── Proving key ──────────────────────────────────────────────────────────────
# Too large (~36 GB) to track; mounted as a volume at runtime.
provingKey/
*.consttree
*.consttree_gpu
*.verkey.bin

# ── Powers of Tau ceremony files ─────────────────────────────────────────────
# Large binary files (97MB–288MB); download separately via snarkjs.
*.ptau

# ── Docker / local environment ───────────────────────────────────────────────
# .env holds COMPOSE_PROFILES and other local overrides; not committed so each
# developer can choose their own profile (cuda / cpu) without affecting others.
.env

# ── Go test binaries ─────────────────────────────────────────────────────────
integration-tests/*.test
integration-tests/vendor/

# ── IDE / OS ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~
.DS_Store
Thumbs.db
