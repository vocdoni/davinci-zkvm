# Docker Compose environment — copy to .env and adjust as needed.
#
# Profile selects which service to start:
#   cuda  — NVIDIA GPU prover (requires nvidia-container-toolkit)
#   cpu   — API-only, no proof generation (ZisK v0.15.0 GPU proving keys
#           are incompatible with CPU provers)
COMPOSE_PROFILES=cuda

# Host path to the ZisK proving key directory (default: ~/.zisk/provingKey).
# The proving key is generated by `cargo-zisk check-setup -a` and is ~36GB.
# PROVING_KEY_PATH=/path/to/provingKey

# Host port to expose the HTTP API on (default: 8080).
# LISTEN_PORT=8080

# Maximum number of jobs in the prove queue (default: 100).
# MAX_QUEUE_SIZE=100
